# Gemini API key — used by the backend to call Gemini (read + audit).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Gemini model for each audit phase (both default to gemini-3.5-flash):
#   GEMINI_EXTRACT_MODEL — stage 1, reads the listing page (uses the urlContext tool)
#   GEMINI_AUDIT_MODEL   — stage 2, audits the page against the profile (JSON schema)
# GEMINI_EXTRACT_MODEL=gemini-3.5-flash
# GEMINI_AUDIT_MODEL=gemini-3.5-flash

# Optional shared key sent as the `X-API-Key` header on /audit. NOT user auth —
# it just stops anonymous callers from draining the Gemini quota. The bundled
# browser extension sends no key, so leave this UNSET when serving that extension
# (the per-IP + global daily caps below bound spend instead). Set it only for a
# private backend whose clients you control; generate one with:
#   bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64url'))"
# If left unset, the server runs unauthenticated (with a startup warning).
AUDIT_API_KEY=

# Optional. Origin allowed by CORS (default "*"). Lock to the extension origin
# (e.g. chrome-extension://<id>) once known.
# ALLOWED_ORIGIN=

# Optional. Port to listen on (default 8787).
# PORT=8787

# Optional. Audit cache TTL in milliseconds (default 3600000 = 1 hour).
# CACHE_TTL_MS=3600000

# Optional. Max /audit requests per client IP per window (default 10). 0 disables.
# RATE_LIMIT_PER_DAY=10

# Optional. Rate-limit window in milliseconds (default 86400000 = 24h).
# RATE_LIMIT_WINDOW_MS=86400000

# Optional. Hard global ceiling on *fresh* audits per day across ALL clients — a
# cap on Gemini spend (default 50). Cache hits don't count. 0 or less disables.
# When hit, /audit returns 429 until the 24h window rolls over.
# GLOBAL_DAILY_AUDITS=50

# The backend only audits car-listing detail pages on supported sites
# (donedeal.ie/cars-for-sale/… and autotrader.co.uk/car-details/…). Any other URL
# is rejected with 400 before any Gemini call. These routes are fixed in code
# (LISTING_ROUTES in src/server.ts) — there's no env knob for them.

# Optional. Postgres connection string for price-history tracking. On Railway,
# add a Postgres database to the project and reference its connection variable
# here (e.g. ${{ Postgres.DATABASE_URL }}). If unset, price tracking is disabled
# (the audit still works) — local/dev and tests run fine without it.
# DATABASE_URL=

# Set this when running behind a proxy / load balancer (Railway, Fly, Nginx) so
# the client IP is read from X-Forwarded-For instead of the (shared) proxy
# socket IP. Leave unset for direct connections. Required for per-IP limiting to
# work correctly behind a proxy.
# TRUST_PROXY=true
