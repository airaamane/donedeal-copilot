{
  "manifest_version": 3,
  "name": "DoneDeal Copilot — Car Audit",
  "version": "1.0.0",
  "description": "AI second opinion on used-car listings. Audits DoneDeal & AutoTrader pages against your buyer profile.",
  "action": {
    "default_title": "DoneDeal Copilot",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.donedeal.ie/*",
    "https://*.autotrader.co.uk/*"
  ]
}
